# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Supabase: use proxy URL in India (Cloudflare Worker), or direct URL elsewhere
# Proxy: https://supabase-proxy.myitihas.workers.dev
# Direct: https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth Client IDs (from Google Cloud Console)
# Web client ID: used as serverClientId for Supabase token verification
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS client ID: used for native Google Sign-In on iOS
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
